# The repo root .env is loaded automatically. These are the recognised settings.
# Required: your OpenAI API key. Either name works (`openai_key` or `OPENAI_API_KEY`).
openai_key=sk-...

# Optional: LangSmith tracing (either `LANGSMITH_API_KEY` or `langsmith_api_key`).
# When a key is set, every LLM call, tool call, and LangGraph node is traced.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=loopp-refund-agent

# Optional overrides (defaults shown):
# AGENT_MODEL=gpt-4o            # e.g. gpt-4o-mini, gpt-4.1, gpt-4.1-mini
# RETURN_WINDOW_DAYS=30
# ESCALATION_THRESHOLD_USD=500
# MAX_AGENT_ITERATIONS=8
